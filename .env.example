# =============================================================
# arremateai-gateway — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha os valores.
# Em desenvolvimento, os defaults do application.yml já funcionam.
# Em produção, TODAS as variáveis abaixo devem ser definidas.
# =============================================================

# --- Servidor ---
SERVER_PORT=8080

# --- JWT (OBRIGATÓRIO — sem default) ---
JWT_SECRET=

# --- URIs dos Microsserviços ---
IDENTITY_URL=http://localhost:8081
MEDIA_URL=http://localhost:8083
PROPERTY_CATALOG_URL=http://localhost:8082
VENDOR_URL=http://localhost:8084
USERPROFILE_URL=http://localhost:8085
ORCHESTRATOR_URL=http://localhost:8087
NOTIFICATION_URL=http://localhost:8086
MONOLITH_URL=http://localhost:8090
SCRAPER_URL=http://localhost:8088

# --- CORS (sobrescrever em produção via propriedades Spring) ---
# Exemplo para sobrescrever allowedOrigins em produção:
#   SPRING_CLOUD_GATEWAY_GLOBALCORS_CORS-CONFIGURATIONS_[/**]_ALLOWEDORIGINS_0=https://app.arremateai.com.br
#   SPRING_CLOUD_GATEWAY_GLOBALCORS_CORS-CONFIGURATIONS_[/**]_ALLOWEDORIGINS_1=https://admin.arremateai.com.br
